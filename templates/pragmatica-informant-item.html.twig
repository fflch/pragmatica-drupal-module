{% import '@pragmatica/pragmatica-macros.html.twig' as macros %}
<div class="mt-4 mb-3">

  <div class="pragmatica-content d-flex gap-2 mb-3" id="informant">
    <div class="d-flex flex-column justify-content-center">
      <h1 class="fs-2" style="color: var(--color-text-dark)">{{ informant.code }}</h1>
{#      <hr class="mt-0 pt-0" style="border: 1px solid var(--color-text-muted)">#}
      <div class=" d-flex gap-4">
        <div class="d-flex flex-column">
          {% if informant.code  %}
            <p class="fs-6"><strong>{{ 'Código' }}:</strong> {{ informant.code }}</p>
          {% endif %}

          {% if informant.age  %}
            <p class="fs-6"><strong>{{ 'Idade' }}:</strong> {{ informant.age }}</p>
          {% endif %}

          {% if informant.gender  %}
            <p class="fs-6"><strong>{{ 'Gênero' }}:</strong> {{ informant.gender }}</p>
          {% endif %}

        </div>
        <div class="d-flex flex-column">
          {% if informant.language  %}
            <p class="fs-6"><strong>{{ 'Línguagem' }}:</strong> {{ informant.language }}</p>
          {% endif %}

          {% if informant.education  %}
            <p class="fs-6"><strong>{{ 'Escolaridade' }}:</strong> {{ informant.education }}</p>
          {% endif %}

          {% if informant.profession  %}
            <p><strong>{{ 'Profissão' }}:</strong> {{ informant.profession }}</p>
          {% endif %}

          {% if informant.city_birth  %}
            <p class="fs-6"><strong>{{ 'Cidade natal' }}:</strong> {{ informant.city_birth }}</p>
          {% endif %}

          {% if informant.city_residency  %}
            <p class="fs-6"><strong>{{ 'Cidade de residência' }}:</strong> {{ informant.city_residency }}</p>
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  <h2 class="mt-3 mb-3 fw-semibold">{{ 'Respostas do informante'|t }}</h2>
  <div class="d-flex flex-column gap-3">
    {% for response in responses %}
      {{ macros.annotation_card(response.label, response.url, null, response.situation, response.tags, loop.index0+1) }}
    {% endfor %}
  </div>


</div>
