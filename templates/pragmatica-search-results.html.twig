{% import '@pragmatica/pragmatica-macros.html.twig' as macros %}

<h1 class="fs-3 mt-3 mb-2">{{ 'Corpus anotado de pedidos'|t }}</h1>

{# ── Filter toggle — plain heading row ───────────────────────────── #}
<button
  class="pragmatica-filter-toggle"
  type="button"
  data-bs-toggle="collapse"
  data-bs-target="#pragmatica-filters-panel"
  aria-expanded="{{ active_filters is empty ? 'true' : 'false' }}"
  aria-controls="pragmatica-filters-panel"
>
  <span class="pragmatica-filter-toggle-label">
    {{ 'Filtros'|t }}
    {% if active_filters is not empty %}
      <span class="pragmatica-filter-count">{{ active_filters|length }}</span>
    {% endif %}
  </span>
  <svg class="pragmatica-filter-chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
    <path fill-rule="evenodd" d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708l6-6z"/>
  </svg>
</button>

{# Collapsible form — closed by default #}
<div class="collapse{{ active_filters is empty ? ' show' : '' }}" id="pragmatica-filters-panel">
  <form method="GET" id="pragmatica-search-form" class="mb-4">
    <div class="accordion accordion-flush" id="pragmatica-filter-accordion">
      {% for group_key, group in filter_groups %}
        {% if group.fields is not empty %}
          <div class="accordion-item pragmatica-filter-group">
            <h3 class="accordion-header m-0">
              <button
                class="accordion-button collapsed pragmatica-filter-group-header"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#filter-group-{{ group_key }}"
                aria-expanded="false"
                aria-controls="filter-group-{{ group_key }}"
              >
                {{ group.label }}
                {% if group.tooltip is defined and group.tooltip %}
                  <span
                    class="pragmatica-tooltip-icon ms-1"
                    data-bs-toggle="tooltip"
                    data-bs-placement="top"
                    title="{{ group.tooltip }}"
                    tabindex="0"
                    role="button"
                    aria-label="Ajuda sobre {{ group.label|lower }}"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
                      <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                      <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/>
                    </svg>
                  </span>
                {% endif %}
              </button>
            </h3>
            <div id="filter-group-{{ group_key }}" class="accordion-collapse collapse">
              <div class="accordion-body p-3">
                <div class="row">
                  {% for field in group.fields %}
                    <div class="{{ group_key == 'situacao' ? 'col-12' : 'col-12 col-md-6 col-lg-4' }}">
                      {{ macros.renderField(field) }}
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="mt-2 d-flex justify-content-between align-items-center">
      <span
        class="pragmatica-tooltip-icon"
        data-bs-toggle="tooltip"
        data-bs-placement="top"
        title="Clique em um campo para abrir as opções disponíveis. Digite para buscar dentro da lista. Para selecionar mais de um item, marque as caixas desejadas. Use &quot;Selecionar todos&quot; para marcar todas as opções de uma vez. Depois de escolher os filtros, clique em &quot;Buscar&quot;."
        tabindex="0"
        role="button"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
          <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/>
        </svg>
      </span>
      <button type="submit" class="btn btn-primary">{{ 'Buscar'|t }}</button>
    </div>
  </form>
</div>

{# Active filters summary — separate element after the collapsible panel #}
{% if active_filters is not empty %}
  <div class="pragmatica-active-filters d-flex flex-wrap gap-2 align-items-baseline mb-2 mt-2">
    {% for filter in active_filters %}
      <span class="pragmatica-active-filter-group">
        <span class="pragmatica-active-filter-label">{{ filter.label }}:</span>
        {% for val in filter.values %}
          <span class="badge rounded-pill pragmatica-active-filter-chip">{{ val }}</span>
        {% endfor %}
      </span>
    {% endfor %}
    <a href="{{ path('pragmatica.public.search') }}" class="btn btn-link btn-sm p-0 ms-1 text-danger">{{ 'Limpar filtros'|t }}</a>
  </div>
{% endif %}

{# ── Results ───────────────────────────────────────────────────────── #}
<div{% if autopins is not empty %} data-autopins="{{ autopins|join(',') }}"{% endif %}>

  {% if has_search %}
    <div class="prag-results-header mt-4">
      <span class="prag-results-header-label">{{ pager.total }} {{ pager.total == 1 ? 'resultado encontrado'|t : 'resultados encontrados'|t }}</span>
      <span class="prag-results-header-rule"></span>
      {% if pager.total_pages > 1 %}
        <div class="prag-results-header-pager">{{ macros.pager(pager, 'pragmatica-search-form', 'pragmatica-page-select-top') }}</div>
      {% endif %}
    </div>

    {% if results.responses %}
      {% for response in results.responses %}
        {{ macros.response_card(response.label, response.url, response.situation, response.informant, response.labels) }}
      {% endfor %}

      <div class="prag-results-header">
        <span class="prag-results-header-rule"></span>
        {% if pager.total_pages > 1 %}
          <div class="prag-results-header-pager">{{ macros.pager(pager, 'pragmatica-search-form', 'pragmatica-page-select-bottom') }}</div>
        {% endif %}
      </div>

    {% else %}
      <div class="prag-no-results">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
        </svg>
        <p>{{ 'Nenhum resultado encontrado para os filtros selecionados.'|t }}</p>
        <a href="{{ path('pragmatica.public.search') }}" class="btn btn-outline-danger btn-sm">{{ 'Limpar filtros'|t }}</a>
      </div>
    {% endif %}

  {% else %}
    {# Initial state — no search performed yet #}
    <div class="prag-no-results">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
      </svg>
      <p>
        {{ 'Para iniciar, clique em um grupo de filtros acima para abrir as opções.<br>
            Dentro de cada campo, clique para selecionar os itens desejados.
            Você pode selecionar vários itens por campo e combinar filtros de grupos diferentes.
            Depois, clique em "Buscar" para ver os resultados.'|t
        }}
      </p>
    </div>
  {% endif %}

</div>

